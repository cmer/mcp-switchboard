{
  "name": "@cmer/mcp-switchboard",
  "version": "1.1.0",
  "type": "module",
  "description": "Self-hosted MCP switchboard: configure MCP servers once, give each coding agent its own endpoint and its own set of tools.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "ai",
    "gateway",
    "proxy",
    "self-hosted"
  ],
  "homepage": "https://github.com/cmer/mcp-switchboard#readme",
  "bugs": "https://github.com/cmer/mcp-switchboard/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmer/mcp-switchboard.git",
    "directory": "server"
  },
  "license": "MIT",
  "author": "Carl Mercier",
  "bin": {
    "mcp-switchboard": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "node ../scripts/prepack.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.0.0",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.11.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
